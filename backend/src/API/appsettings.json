{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://127.0.0.1:4200"
    ]
  },
  "ConnectionStrings": {
    "Postgres": "",
    "DefaultConnection": ""
  },
  "Database": {
    "_comment": "PostgreSQL is the hosted/Docker default. Conductor's embedded launcher overrides this with Database__Provider=Sqlite via environment variables.",
    "Provider": "PostgreSql"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JWT": {
    "SecretKey": "",
    "Issuer": "DevPilot",
    "Audience": "DevPilot"
  },
  "AuthProviders": {
    "Local": {
      "Enabled": true
    },
    "GitHub": {
      "Enabled": true,
      "Type": "BackendOAuth",
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:4200/auth/callback/GitHub",
      "Scopes": "repo,read:org"
    },
    "AzureAd": {
      "Enabled": true,
      "Type": "FrontendOidc",
      "Authority": "https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0",
      "ClientId": "",
      "SpaClientId": "",
      "TenantId": "YOUR_TENANT_ID",
      "Scopes": "openid profile email User.Read",
      "ProfileEndpoint": "https://graph.microsoft.com/v1.0/me"
    },
    "Duende": {
      "Enabled": false,
      "Type": "FrontendOidc",
      "Authority": "https://your-identityserver.com",
      "ClientId": "",
      "SpaClientId": "",
      "Scopes": "openid profile email",
      "ProfileEndpoint": ""
    }
  },
  "AI": {
    "Endpoint": "https://api.openai.com/v1",
    "ApiKey": "",
    "Model": "gpt-4",
    "UseAzureOpenAI": false
  },
  "VPS": {
    "GatewayUrl": "http://localhost:8090",
    "SessionTimeoutMinutes": 60,
    "Enabled": false
  },
  "UnpublishedRepositories": {
    "RootPath": "",
    "DownloadBaseUrl": ""
  }
}
