# ============================================================
# DevPilot — Local development secrets
# Copy this file to .env and fill in your values.
# .env is gitignored and will NEVER be committed.
# ============================================================

# Shared API key between the backend and the sandbox manager.
# Same value must be set here AND in appsettings.Development.json > VPS:ManagerApiKey
# (or as VPS__ManagerApiKey so .NET picks it up automatically).
MANAGER_API_KEY=your_api_key_here
VPS__ManagerApiKey=your_api_key_here
