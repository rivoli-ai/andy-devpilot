# ============================================================
# DevPilot — Local development secrets
# Copy this file to .env and fill in your values.
# .env is gitignored and will NEVER be committed.
# ============================================================

# Optional: PostgreSQL (docker compose “postgres” service + devpilot-backend).
# These defaults must match ConnectionStrings:DefaultConnection in
# backend/src/API/appsettings.Development.json when you use
# User=analyser / Database=analyzer (Host=localhost for dotnet run, Host=postgres in compose).
# Override if you change your local JSON credentials.
# DB_USER=analyser
# DB_PASSWORD=analyser_password
# DB_NAME=analyzer

# Shared API key between the backend and the sandbox manager.
# Same value must be set here AND in appsettings.Development.json > VPS:ManagerApiKey
# (or as VPS__ManagerApiKey so .NET picks it up automatically).
MANAGER_API_KEY=your_api_key_here
VPS__ManagerApiKey=your_api_key_here

# NOTE: The BACKEND env var (docker vs k8s) is NOT set here.
# It is only relevant for the K8s setup — configure it in infra/sandbox/k8s/.env instead.
# Linux / macOS / Windows setups always use BACKEND=docker (default).
