# ============================================================
# DevPilot — Local stack secrets
# Copy this file to ../../.env (repo root) and fill in your values.
# .env is gitignored and will NEVER be committed.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_USER=analyser
DB_PASSWORD=analyser_password
DB_NAME=analyzer

# ── JWT ───────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET_KEY=change-me-to-a-strong-secret-key-min-32-chars

# ── Auth providers ────────────────────────────────────────────
AuthProviders__Local__Enabled=true

AuthProviders__GitHub__Enabled=true
AuthProviders__GitHub__Type=BackendOAuth
AuthProviders__GitHub__ClientId=your_github_oauth_app_client_id
AuthProviders__GitHub__ClientSecret=your_github_oauth_app_client_secret
AuthProviders__GitHub__RedirectUri=http://localhost/auth/callback/GitHub
AuthProviders__GitHub__Scopes=repo,read:org

# Azure AD (set Enabled=false to disable)
AuthProviders__AzureAd__Enabled=false
AuthProviders__AzureAd__Type=FrontendOidc
AuthProviders__AzureAd__Authority=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
AuthProviders__AzureAd__ClientId=your_azure_ad_client_id
AuthProviders__AzureAd__SpaClientId=your_azure_ad_client_id
AuthProviders__AzureAd__TenantId=your_azure_ad_tenant_id
AuthProviders__AzureAd__Scopes="openid profile email User.Read"
AuthProviders__AzureAd__ProfileEndpoint=https://graph.microsoft.com/v1.0/me

# Duende IdentityServer (set Enabled=false to disable)
AuthProviders__Duende__Enabled=false
AuthProviders__Duende__Type=FrontendOidc
AuthProviders__Duende__Authority=https://localhost:5001
AuthProviders__Duende__ClientId=devpilot-spa
AuthProviders__Duende__SpaClientId=devpilot-spa
AuthProviders__Duende__Scopes="openid profile email"
AuthProviders__Duende__ProfileEndpoint=https://localhost:5001/connect/userinfo
AuthProviders__Duende__DangerousAcceptAnyServerCertificate=true

# ── AI ────────────────────────────────────────────────────────
AI_ENDPOINT=https://router.huggingface.co/v1
AI_API_KEY=your_ai_api_key
AI_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# ── Sandbox Manager ───────────────────────────────────────────
# Shared key between backend and sandbox manager
MANAGER_API_KEY=change-me-to-a-strong-random-key

# Public IP shown to the browser for VNC and Bridge API URLs
# Use 'localhost' for local dev, your machine IP for LAN access
PUBLIC_IP=localhost

# Gateway URL used by the backend to reach the sandbox manager.
# Patched automatically by start.sh / start.ps1 based on mode:
#   Docker → http://localhost:8090
#   K8s    → http://localhost:30090
VPS__GatewayUrl=http://localhost:8090

# ── Frontend ──────────────────────────────────────────────────
# Keep /api when frontend + backend share the same host (nginx proxies).
# Change to a full URL (e.g. https://api.example.com/api) for split-host setups.
API_URL=/api
