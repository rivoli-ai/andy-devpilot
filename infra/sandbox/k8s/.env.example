# ============================================================
# Sandbox Manager — K8s local setup secrets
# Copy this file to .env and fill in your values.
# .env is gitignored and will NEVER be committed.
# ============================================================

# API key protecting the sandbox manager endpoints.
# Must match VPS:ManagerApiKey in backend/src/API/appsettings.Development.json
MANAGER_API_KEY=your_api_key_here
