# Copy this file to backend-secret.yaml, fill in the values, then:
#   kubectl apply -f backend-secret.yaml -n devpilot
# NEVER commit backend-secret.yaml — it is gitignored.
#
# On AKS you can create it directly without a file:
#   kubectl create secret generic backend-secrets -n devpilot \
#     --from-literal=ConnectionStrings__Postgres="Host=...;Username=...;Password=...;Database=..." \
#     --from-literal=JWT__SecretKey="YOUR_STRONG_JWT_SECRET" \
#     --from-literal=AuthProviders__GitHub__ClientSecret="YOUR_GITHUB_SECRET" \
#     --from-literal=AI__ApiKey="YOUR_AI_KEY" \
#     --from-literal=VPS__ManagerApiKey="YOUR_MANAGER_API_KEY"
apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: devpilot
type: Opaque
stringData:
  # Database
  ConnectionStrings__Postgres: "Host=YOUR_DB_HOST;Port=5432;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Database=analyzer"

  # JWT
  JWT__SecretKey: "YOUR_STRONG_JWT_SECRET_MIN_32_CHARS"

  # GitHub OAuth
  AuthProviders__GitHub__ClientId: "YOUR_GITHUB_CLIENT_ID"
  AuthProviders__GitHub__ClientSecret: "YOUR_GITHUB_CLIENT_SECRET"

  # AI
  AI__Endpoint: "https://router.huggingface.co/v1"
  AI__ApiKey: "YOUR_AI_API_KEY"
  AI__Model: "Qwen/Qwen3-30B-A3B-Instruct-2507"

  # Sandbox Manager — same key as MANAGER_API_KEY in manager-secret.yaml
  VPS__GatewayUrl: "http://sandbox-manager.sandboxes.svc.cluster.local:8090"
  VPS__ManagerApiKey: "YOUR_MANAGER_API_KEY"
  VPS__PublicIp: "YOUR_AKS_NODE_PUBLIC_IP_OR_LOADBALANCER_IP"
