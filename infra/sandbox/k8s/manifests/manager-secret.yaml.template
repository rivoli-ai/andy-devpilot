# Copy this file to manager-secret.yaml, fill in the values, then:
#   kubectl apply -f manager-secret.yaml
# NEVER commit manager-secret.yaml — it is gitignored.
apiVersion: v1
kind: Secret
metadata:
  name: manager-secrets
  namespace: sandboxes
type: Opaque
stringData:
  MANAGER_API_KEY: "YOUR_STRONG_RANDOM_KEY"
  HOST_IP: "YOUR_VPS_IP_OR_localhost"
  BACKEND: "k8s"
  SANDBOX_IMAGE: "ghcr.io/YOUR_ORG/devpilot-desktop:latest"
  IMAGE_PULL_SECRET: "ghcr-secret"
